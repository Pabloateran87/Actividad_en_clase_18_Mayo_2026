%%{init: {'theme':'default', 'themeVariables': {'primaryColor':'#f5f5f5', 'primaryBorderColor':'#1565c0', 'primaryTextColor':'#212121', 'secondaryColor':'#e3f2fd', 'secondaryBorderColor':'#1976d2', 'tertiaryColor':'#fff3e0', 'tertiaryBorderColor':'#f57c00', 'lineColor':'#424242', 'textColor':'#212121', 'mainBkg':'#ffffff', 'nodeBorder':'#1565c0', 'clusterBkg':'#fafafa', 'clusterBorder':'#757575', 'edgeLabelBackground':'#ffffff', 'fontSize':'14px'}}}%%

flowchart LR
    A[PDFs] --> B[Fragmentar y<br/>Vectorizar]
    B --> C[ChromaDB]
    
    C --> D[Flask Server<br/>RAG Activo]
    
    D --> E[Mensaje<br/>Usuario]
    
    E --> F{Crisis?}
    F -->|Si| G[EMERGENCIA]
    F -->|No| H[Busqueda RAG]
    
    H --> I[Contexto +<br/>Historial]
    I --> J[OpenAI<br/>GPT-4o-mini]
    J --> K[Respuesta<br/>Usuario]
    
    K --> L{Exportar?}
    L -->|Si| M[PDF]
    L -->|No| E
    
    %% ESTILOS FORMALES
    classDef default fill:#f5f5f5,stroke:#1565c0,stroke-width:2px,color:#212121
    classDef crisis fill:#ffebee,stroke:#c62828,stroke-width:2px,color:#c62828
    classDef success fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#1b5e20
    classDef decision fill:#fff3e0,stroke:#ef6c00,stroke-width:2px,color:#e65100
    classDef process fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#0d47a1
    
    class G crisis
    class D,K success
    class F,L decision
    class B,H,I,J process